# Novari backend environment configuration.
# Copy this file to .env and adjust. .env is gitignored — never commit real credentials.
#
# docker-compose.yml maps host port 5433 -> container 5432 to avoid clashing
# with other local Postgres on 5432. Docker Compose reads this same .env file
# for ${VAR} substitution, so the DB password below must match what Django uses.

# --- Django ---
# Generate a strong key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=dev-insecure-key-change-for-production

# Set "true" for local development (serves media, shows error pages).
# Leave "false" (or unset) for production.
DJANGO_DEBUG=true

# Comma-separated hosts the API accepts. Production: "api.yourdomain.com".
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated storefront origins allowed to call the API.
# Production: "https://yourdomain.com,https://www.yourdomain.com".
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Database ---
DB_NAME=novari_db
DB_USER=novari_user
DB_PASSWORD=change-me-for-production
DB_HOST=localhost
DB_PORT=5433

# --- Seed command (optional) ---
# Used by `python manage.py seed_products`. If SEED_ADMIN_PASSWORD is unset,
# a strong random password is generated and printed to the console.
# For the documented local dev credentials, uncomment and set:
# SEED_ADMIN_EMAIL=admin@novari.test
# SEED_ADMIN_PASSWORD=changeme123
